{
  "name": "taskbar.fm",
  "version": "3.0.0",
  "description": "Taskbar like windows for mac",
  "author": "FruitRiin",
  "homepage": "https://github.com/fruitriin/taskbar",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "build:mac": "tauri build",
    "release:mac": "sh scripts/build-release.sh",
    "install-app": "rm -rf /Applications/taskbar.fm.app && cp -a src-tauri/target/release/bundle/macos/taskbar.fm.app /Applications/taskbar.fm.app",
    "format": "bunx oxfmt src-renderer vite.config.ts uno.config.ts",
    "lint": "bunx oxlint -c .oxlintrc.json .",
    "typecheck": "npx vue-tsc --noEmit -p src-renderer/tsconfig.web.json --composite false",
    "test": "cd src-renderer && bun test tests/ --preload ./tests/setup.ts --env happy-dom",
    "test:all": "bun run test && cd src-tauri && cargo test",
    "vite:dev": "vite --config vite.config.ts",
    "vite:build": "vite build --config vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "fast-sort": "^3.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.14",
    "@types/node": "20.9.0",
    "@vitejs/plugin-vue": "^4.4.1",
    "@vueuse/core": "^13.2.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^5.2.2",
    "unocss": "^66.7.4",
    "vite": "^8.1.4",
    "vue": "^3.3.8",
    "vue-tsc": "^1.8.22",
    "vuedraggable": "^4.1.0"
  }
}
