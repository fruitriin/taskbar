{
  "name": "taskbar.fm",
  "version": "2.1.1",
  "description": "Taskbar like windows for mac",
  "main": "./out/main/index.js",
  "author": "FruitRiin",
  "homepage": "https://www.electronjs.org",
  "scripts": {
    "dev": "cp nativeSrc/DerivedData/taskbar.helper/Build/Products/Release/taskbar.helper resources/TaskbarHelper & npx electron-vite dev",
    "build": "cp nativeSrc/DerivedData/taskbar.helper/Build/Products/Release/taskbar.helper resources/TaskbarHelper && npx electron-vite build",
    "swiftbuild": "xcodebuild -project nativeSrc/taskbar.helper.xcodeproj -scheme taskbar.helper -configuration Release -derivedDataPath nativeSrc/DerivedData/taskbar.helper build && echo '[COPY]binary copy to resouces' && cp nativeSrc/DerivedData/taskbar.helper/Build/Products/Release/taskbar.helper resources/TaskbarHelper && echo '[COPY] done.'",
    "build:mac": "bun run build && npx electron-builder --mac --universal",
    "install-app": "rm -rf /Applications/taskbar.fm.app && cp -a dist/mac-universal/taskbar.fm.app /Applications/taskbar.fm.app",
    "helper": "open nativeSrc/taskbar.helper.xcodeproj/project.xcworkspace",
    "format": "bunx oxfmt src electron.vite.config.ts uno.config.ts",
    "lint": "bunx oxlint -c .oxlintrc.json .",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "typecheck:node": "npx tsc --noEmit -p src/main/tsconfig.node.json --composite false",
    "typecheck:web": "npx vue-tsc --noEmit -p src/renderer/tsconfig.web.json --composite false",
    "test": "cd src/main && bun test tests/ --preload ./tests/setup.ts",
    "test:renderer": "cd src/renderer && bun test tests/ --preload ./tests/setup.ts --env happy-dom",
    "test:all": "bun run test && bun run test:renderer",
    "test:swift": "cd nativeSrc && swift test",
    "vite:dev": "vite --config vite.config.ts",
    "vite:build": "vite build --config vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "prettierIgnore": [
    "out",
    "dist",
    "pnpm-lock.yaml",
    "LICENSE.md",
    "tsconfig.json",
    "tsconfig.*.json"
  ],
  "eslintIgnore": [
    "node_modules",
    "dist",
    "out",
    ".gitignore",
    ".env",
    "build"
  ],
  "dependencies": {
    "@electron-toolkit/preload": "^2.0.0",
    "@electron-toolkit/utils": "^2.0.1",
    "@fortawesome/fontawesome-free": "^7.3.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "electron-updater": "^6.1.4",
    "fast-sort": "^3.4.0",
    "riinlogger": "file:../RiinLogger"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/notarize": "^2.1.0",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.14",
    "@types/node": "20.9.0",
    "@vitejs/plugin-vue": "^4.4.1",
    "@vueuse/core": "^13.2.0",
    "dotenv": "^16.3.1",
    "electron": "^27.0.4",
    "electron-builder": "^24.6.4",
    "electron-store": "^8.1.0",
    "electron-vite": "^1.0.28",
    "html-escaper": "^3.0.3",
    "just-diff": "^6.0.2",
    "just-diff-apply": "^5.5.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "sass": "^1.101.0",
    "typescript": "^5.2.2",
    "unocss": "^66.7.4",
    "vite": "^8.1.4",
    "vue": "^3.3.8",
    "vue-tsc": "^1.8.22",
    "vuedraggable": "^4.1.0"
  }
}
