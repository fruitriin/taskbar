{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/reset-turn-count.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-recovery.sh",
            "trigger": "compact"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/turn-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/skill-usage-log.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(resources/TaskbarHelper:*)",
      "Bash(bun run build)",
      "Bash(bun run build:mac)",
      "Bash(bun run typecheck)",
      "Bash(bun run lint)",
      "Bash(bun run format)",
      "Bash(bun run test)",
      "Bash(bun run test:renderer)",
      "Bash(bun run test:all)",
      "Bash(codesign:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "LSP",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TeamCreate",
      "TeamDelete",
      "SendMessage",
      "ToolSearch",
      "Bash(* --help)",
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(cp *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(tail *)",
      "Bash(cd *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rm *)",
      "Bash(git ls-files *)",
      "Bash(git branch *)",
      "Bash(git worktree *)",
      "Bash(git checkout *)",
      "Bash(git show *)",
      "Bash(git merge *)",
      "Bash(git stash *)",
      "Bash(git clone *)",
      "Bash(git -C *)",
      "Bash(mktemp *)",
      "Bash(which *)",
      "Bash(gh repo view *)",
      "Bash(gh repo list *)",
      "Bash(gh repo clone *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh issue status *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr checkout *)",
      "Bash(bash .claude/tests/run-all.sh *)",
      "Bash(uv run --python 3.11 .claude/addfTools/lint *)",
      "Bash(bun run dev:web)",
      "Bash(cargo check)",
      "Bash(cargo clippy *)",
      "Bash(cargo test)",
      "Bash(cargo fmt)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)"
    ]
  }
}
