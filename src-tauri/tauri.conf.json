{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "taskbar.fm",
  "version": "3.0.0",
  "identifier": "space.riinswork.taskbar",
  "build": {
    "devUrl": "http://localhost:10234",
    "frontendDist": "../dist",
    "beforeDevCommand": "bun run vite:dev",
    "beforeBuildCommand": "bun run vite:build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "Developer ID Application: Rin Nakashima (4Z474DZ677)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
